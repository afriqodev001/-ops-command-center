# ============================================================
# Ops Command Center — environment variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is checked in.
#
# Auto-loading: settings.py calls python-dotenv at startup, so once this
# file is in the repo root the Django dev server AND the Celery worker
# both pick up the values on their next restart. No shell export needed.
#
# If python-dotenv isn't installed (e.g. stripped-down env), fall back to:
#   set -a; source .env; set +a
#   python manage.py runserver


# ─── Django ─────────────────────────────────────────────────
# Rotate this for any real deployment. `python -c "import secrets; print(secrets.token_urlsafe(50))"`
DJANGO_SECRET_KEY=django-insecure-change-me-for-production

# 'True' for dev, 'False' for prod
DJANGO_DEBUG=True

# Comma-separated. Empty means Django defaults (localhost only in debug).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1


# ─── ServiceNow ─────────────────────────────────────────────
# Your instance URL, including the scheme. No trailing slash.
SERVICENOW_BASE=https://your-instance.service-now.com


# ─── AI-assisted creation ───────────────────────────────────
# API key for the LLM used by "Suggest fields with AI" on create forms.
# Supports Claude (Anthropic) or OpenAI — set the key for whichever you use.
# Leave blank to disable AI suggestions (the button shows "not configured").
AI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# ─── Tachyon Playground ─────────────────────────────────────
# Your Tachyon Studio instance URL. Used for browser-based LLM calls.
TACHYON_BASE=https://your-tachyon-instance.net
TACHYON_DEFAULT_USER_ID=localuser

# ─── Splunk ─────────────────────────────────────────────────
# Your Splunk Cloud or Enterprise URL. No trailing slash.
SPLUNK_BASE=https://your-splunk.splunkcloud.com
# The Splunk app namespace used for API calls.
SPLUNK_APP=search
# The namespace user for API calls (servicesNS/<user>/<app>/...).
# Use your Splunk username or 'nobody' for shared context.
SPLUNK_NAMESPACE_USER=nobody

# ─── Copilot Chat ──────────────────────────────────────────
# Microsoft Teams URL for Copilot browser automation.
COPILOT_TEAMS_URL=https://teams.microsoft.com/v2/

# ─── Browser automation (Windows) ───────────────────────────
# Full path to Microsoft Edge. Leave commented for the built-in default.
# EDGE_EXE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# Override the Edge profile directory base (optional).
# Defaults to %LOCALAPPDATA%\CopilotOps\EdgeProfiles when unset.
# BROWSER_PROFILE_BASE=
